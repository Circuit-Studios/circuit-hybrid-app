# apps/api/.env.example — template for local API. Copy via: npm run setup:env:api
#
# Used ONLY when running the backend locally (npm run api:dev).
# Deployed backend config lives in the Render dashboard — never copy prod values here.
#
# Do not commit real values; only this .env.example is tracked.
#
# See ../../docs/ENVIRONMENT.md for the three workflows (Render-only mobile, full local, prod).

NODE_ENV=development
APP_ENV=local
PORT=3009
LOG_LEVEL=debug

# Local Docker Postgres (docker compose up -d) or Supabase DEV project — not production.
DATABASE_URL=postgresql://circuit:circuit@localhost:5432/circuit_dev?schema=public

JWT_SECRET=replace_with_local_long_secret_min_32_chars
JWT_ISSUER=circuit-api
JWT_AUDIENCE=circuit-mobile
JWT_EXPIRES_IN=7d

# --- Sign up vs Sign in (independent) ---
# SIGNUP: which channel receives the OTP when creating an account
SIGNUP_VERIFICATION_CHANNEL=EMAIL
# SIGNIN (mobile app): email + password via POST /auth/login — not OTP
# LOGIN_IDENTIFIER: legacy OTP login only (/auth/request-otp with purpose=login)
#   EMAIL | PHONE | BOTH — does not affect mobile Sign In (email + password)
LOGIN_IDENTIFIER=EMAIL
EMAIL_OTP_PROVIDER=MOCK
PHONE_OTP_PROVIDER=MOCK
ALLOW_MOCK_OTP_IN_PROD=false

# Legacy alias — prefer EMAIL_OTP_PROVIDER / PHONE_OTP_PROVIDER
OTP_PROVIDER=MOCK
OTP_SECRET=replace_with_local_otp_secret_min_32_chars

# Phone OTP (when PHONE_OTP_PROVIDER=MSG91)
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=
# MSG91_TEMPLATE_ID=

# Email OTP via Resend hosted template (when EMAIL_OTP_PROVIDER=RESEND)
# Template From + Subject are configured in the Resend dashboard.
# EMAIL_OTP_PROVIDER=RESEND
# RESEND_API_KEY=re_xxxxx
# RESEND_OTP_TEMPLATE_ID=circuit-email-otp
# RESEND_OTP_EXPIRES_MINUTES=5

# Optional — local dev only: skip OTP and POST /auth/register directly
# ALLOW_DIRECT_REGISTER=false

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MAX_RETRIES=3

LANGSMITH_TRACING=false

EXPO_PUSH_PROVIDER=MOCK

CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Optional — omit this line entirely unless Redis is running locally.
# REDIS_URL=redis://localhost:6379
