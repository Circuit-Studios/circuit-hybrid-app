# apps/api/.env.development — local API only (gitignored). Copy via: npm run setup:env
#
# Used ONLY when running the backend locally (npm run api:dev).
# Deployed backend config lives in the Render dashboard — never copy prod values here.
#
# Do not commit real values; only this .env.example is tracked.
#
# See ../../docs/ENVIRONMENT.md for the three workflows (Render-only mobile, full local, prod).

NODE_ENV=development
PORT=3009
LOG_LEVEL=debug

# Local Docker Postgres (docker compose up -d) or Supabase DEV project — not production.
DATABASE_URL=postgresql://circuit:circuit@localhost:5432/circuit_dev?schema=public

JWT_SECRET=replace_with_local_long_secret_min_32_chars
JWT_ISSUER=circuit-api
JWT_AUDIENCE=circuit-mobile
JWT_EXPIRES_IN=7d

OTP_PROVIDER=MOCK
OTP_EMAIL_PROVIDER=MOCK
EMAIL_FROM=Circuit <noreply@circuit.app>
# RESEND_API_KEY=re_xxx

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MAX_RETRIES=3

LANGSMITH_TRACING=false

EXPO_PUSH_PROVIDER=MOCK

CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Optional — omit this line entirely unless Redis is running locally.
# Conflict scans run inline on the request thread when REDIS_URL is absent.
# REDIS_URL=redis://localhost:6379
