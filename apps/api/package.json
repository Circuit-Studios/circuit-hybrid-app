{
  "name": "circuit-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Circuit MVP backend — Node.js + Express + Prisma + OpenAI.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/server/index.js",
    "setup:env": "sh -c 'if [ -f .env.development ]; then echo \"apps/api/.env.development already exists — skipping\"; else cp .env.example .env.development && echo \"Created apps/api/.env.development from .env.example\"; fi'",
    "db:prepare:dev": "NODE_ENV=development node scripts/with-env.mjs bash -c 'npx prisma migrate deploy && npx prisma generate'",
    "dev:db": "npm run db:prepare:dev",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "NODE_ENV=development node scripts/with-env.mjs npx prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:dev": "NODE_ENV=development node scripts/with-env.mjs npx prisma migrate deploy",
    "prisma:studio": "NODE_ENV=development node scripts/with-env.mjs npx prisma studio",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.6",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.74.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.0",
    "@types/pdf-parse": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
