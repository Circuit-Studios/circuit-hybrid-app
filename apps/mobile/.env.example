# apps/mobile/.env — local Expo Metro only (gitignored). Copy via: npm run setup:env
#
# EAS cloud builds: set EXPO_PUBLIC_* in EAS Environment Variables — not in eas.json.
# Deployed API secrets never belong here — only the public API base URL.
#
# NEVER use EXPO_PUBLIC_* for: database URLs, API keys, JWT secrets.
#
# See ../../docs/ENVIRONMENT.md

# --- Workflow A (default): mobile → Render backend ---
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://circuit-api-dev.onrender.com

# --- Workflow B: mobile → local backend (uncomment when running npm run api:dev) ---
# EXPO_PUBLIC_APP_ENV=local
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3009

# Physical device on same WiFi — use your laptop LAN IP instead of localhost:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:3009
