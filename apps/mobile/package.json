    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "expo": "^56.0.11",
    "expo-asset": "^56.0.17",
    "expo-constants": "^56.0.18",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "^56.0.14",
    "expo-notifications": "^56.0.17",
    "expo-router": "~56.2.10",
