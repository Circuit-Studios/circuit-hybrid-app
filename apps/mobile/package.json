{
  "name": "circuit-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:offline": "EXPO_OFFLINE=1 expo start",
    "ios": "expo start --ios --localhost",
    "ios:tunnel": "expo start --ios --tunnel",
    "ios:first-run": "expo start --ios --localhost",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "jest",
    "setup:env": "sh -c 'test -f .env || cp .env.example .env'",
    "generate:brand": "node scripts/generate-brand-assets.mjs"
  },
  "dependencies": {
